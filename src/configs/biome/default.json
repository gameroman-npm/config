{
  "$schema": "../../../node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineEnding": "lf"
  },
  "assist": {
    "actions": {
      "source": { "organizeImports": "on", "useSortedPackageJson": "on" }
    }
  },
  "linter": {
    "rules": {
      "style": {
        "useNodejsImportProtocol": "error",
        "noNonNullAssertion": "error",
        "useConst": "error"
      },
      "suspicious": { "noExplicitAny": "error", "noVar": "error" },
      "nursery": { "noRestrictedDependencies": "error" }
    }
  },
  "html": {
    "formatter": { "enabled": true, "selfCloseVoidElements": "always" },
    "experimentalFullSupportEnabled": true
  }
}
